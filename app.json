{
  "expo": {
    "name": "CBRio",
    "slug": "aplicativo-cbrio",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cbrio",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/app-icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1F26"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.com.cbrio.app",
      "appleTeamId": "AK67335XW5",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O CBRio usa sua localização para mostrar grupos próximos no mapa e confirmar sua presença no NEXT.",
        "NSMotionUsageDescription": "O CBRio usa o sensor de movimento para o efeito holográfico do seu cartão.",
        "NSFaceIDUsageDescription": "O CBRio usa o Face ID para você desbloquear o app com segurança, sem digitar sua senha.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.in-app-payments": [
          "merchant.br.com.cbrio.app"
        ]
      }
    },
    "android": {
      "package": "br.com.cbrio.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/cbrio-heart.png",
        "backgroundColor": "#eae3da"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/cbrio-chime.wav"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O CBRio usa suas fotos para definir o avatar do seu perfil."
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "O CBRio usa o Face ID para você desbloquear o app com segurança, sem digitar sua senha."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3da60261-4811-458b-90c7-7e81f5511c51"
      }
    },
    "owner": "mtoscano99",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3da60261-4811-458b-90c7-7e81f5511c51"
    }
  }
}