{
  "expo": {
    "name": "CBRio",
    "slug": "aplicativo-cbrio",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cbrio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B1F26"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.cbrio.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "br.com.cbrio.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-apple-authentication"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
